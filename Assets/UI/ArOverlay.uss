.ar-screen {
    flex-grow: 1;
    width: 100%;
    height: 100%;
}

.ar-container {
    flex-grow: 1;
    width: 100%;
    height: 100%;
    justify-content: space-between;
    padding: 22px;
}

.ar-top-row {
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
}

.ar-circle-btn {
    width: 72px;
    height: 72px;
    border-radius: 36px;
    border-width: 0;
    background-color: rgb(245, 247, 251);
    color: rgb(7, 29, 66);
    font-size: 24px;
    -unity-font-style: bold;
}

.direction-bar {
    flex-grow: 1;
    margin-left: 12px;
    margin-right: 12px;
    height: 72px;
    border-radius: 36px;
    background-color: rgb(20, 111, 226);
    flex-direction: row;
    align-items: center;
    padding-left: 12px;
    padding-right: 12px;
}

.direction-audio {
    width: 40px;
    height: 40px;
    border-radius: 20px;
    border-width: 0;
    background-color: rgba(255, 255, 255, 0.2);
    color: white;
    -unity-font-style: bold;
    margin-right: 10px;
}

.direction-text {
    color: white;
    font-size: 18px;
    -unity-font-style: bold;
}

.ar-help-btn {
    width: 72px;
    height: 72px;
    align-self: flex-end;
    border-radius: 36px;
    border-width: 0;
    background-color: rgb(245, 247, 251);
    color: rgb(7, 29, 66);
    font-size: 28px;
    -unity-font-style: bold;
    margin-top: 16px;
}

.ar-mid-marker {
    align-items: center;
    margin-top: 30px;
}

.ar-arrow {
    width: 166px;
    height: 116px;
    background-color: rgb(20, 111, 226);
    border-radius: 14px;
}

.ar-distance-pill {
    width: 120px;
    height: 48px;
    margin-top: 10px;
    border-radius: 24px;
    background-color: rgb(20, 111, 226);
    justify-content: center;
    align-items: center;
}

.ar-distance-text {
    color: white;
    font-size: 24px;
    -unity-font-style: bold;
}

.bottom-card {
    width: 100%;
    border-radius: 32px;
    background-color: rgb(250, 251, 253);
    padding: 24px;
    margin-bottom: 8px;
}

.destination-label {
    font-size: 20px;
    letter-spacing: 2px;
    color: rgb(48, 58, 78);
    -unity-font-style: bold;
    margin-bottom: 8px;
}

.destination-title {
    font-size: 32px;
    -unity-font-style: bold;
    color: rgb(6, 28, 67);
    margin-bottom: 12px;
}

.card-actions {
    flex-direction: row;
    justify-content: space-between;
}

.btn-rescan {
    width: 46%;
    height: 76px;
    border-radius: 38px;
    border-width: 0;
    background-color: rgb(214, 225, 245);
    color: rgb(20, 103, 223);
    -unity-font-style: bold;
    font-size: 20px;
}

.btn-end {
    width: 46%;
    height: 76px;
    border-radius: 38px;
    border-width: 0;
    background-color: rgb(176, 67, 0);
    color: white;
    -unity-font-style: bold;
    font-size: 20px;
}

.recovery-screen {
    flex-grow: 1;
    background-color: rgb(244, 246, 252);
}

.recovery-top-bar {
    height: 76px;
    flex-shrink: 0;
    flex-direction: row;
    align-items: center;
    padding-left: 24px;
    padding-right: 24px;
    background-color: rgb(249, 250, 253);
    border-bottom-width: 1px;
    border-bottom-color: rgb(230, 235, 244);
}

.recovery-menu-icon {
    width: 18px;
    height: 14px;
    border-radius: 3px;
    background-color: rgb(20, 103, 223);
    margin-right: 14px;
}

.recovery-brand-text {
    font-size: 22px;
    -unity-font-style: bold;
    color: rgb(6, 28, 67);
}

.recovery-scroll {
    flex-grow: 1;
    width: 100%;
}

.recovery-content {
    flex-grow: 1;
    width: 100%;
    padding: 22px;
    align-items: center;
}

.recovery-icon-circle {
    width: 160px;
    height: 160px;
    border-radius: 80px;
    background-color: rgb(240, 242, 245);
    justify-content: center;
    align-items: center;
    margin-top: 4px;
    margin-bottom: 20px;
}

.recovery-icon {
    width: 74px;
    height: 74px;
    border-radius: 37px;
    background-color: rgb(176, 67, 0);
}

.recovery-title {
    width: 100%;
    color: rgb(5, 30, 73);
    font-size: 38px;
    -unity-font-style: bold;
    -unity-text-align: middle-center;
    margin-bottom: 10px;
}

.recovery-desc {
    width: 100%;
    color: rgb(39, 52, 75);
    font-size: 14px;
    -unity-text-align: middle-center;
    white-space: normal;
    padding-left: 22px;
    padding-right: 22px;
    margin-bottom: 18px;
}

.recovery-step-card {
    width: 100%;
    border-radius: 16px;
    background-color: rgb(206, 218, 240);
    padding: 18px;
    margin-bottom: 12px;
}

.recovery-step-head {
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 10px;
}

.recovery-step-index {
    color: rgb(42, 53, 74);
    font-size: 12px;
    letter-spacing: 2px;
    -unity-font-style: bold;
}

.recovery-step-icon {
    width: 22px;
    height: 22px;
    border-radius: 6px;
    background-color: rgb(20, 103, 223);
}

.recovery-step-title {
    color: rgb(8, 25, 57);
    font-size: 22px;
    -unity-font-style: bold;
    margin-bottom: 8px;
}

.recovery-step-body {
    color: rgb(39, 52, 75);
    font-size: 13px;
    white-space: normal;
    margin-bottom: 10px;
}

.recovery-cancel-btn {
    align-self: flex-start;
    margin-top: 6px;
    border-width: 0;
    background-color: transparent;
    color: rgb(89, 98, 113);
    -unity-font-style: bold;
    font-size: 13px;
}

.recovery-step-btn {
    align-self: flex-start;
    height: 42px;
    border-radius: 21px;
    border-width: 0;
    background-color: rgb(20, 111, 226);
    color: white;
    -unity-font-style: bold;
    font-size: 13px;
    padding-left: 16px;
    padding-right: 16px;
}

.recovery-tip {
    width: 100%;
    margin-top: 6px;
    border-radius: 16px;
    background-color: rgb(248, 249, 251);
    padding: 12px;
    flex-direction: row;
    align-items: center;
}

.recovery-tip-icon {
    width: 54px;
    height: 54px;
    border-radius: 12px;
    background-color: rgb(30, 33, 41);
    margin-right: 12px;
}

.recovery-tip-copy {
    flex-grow: 1;
}

.recovery-tip-title {
    color: rgb(47, 55, 69);
    font-size: 11px;
    -unity-font-style: bold;
}

.recovery-tip-text {
    color: rgb(18, 31, 54);
    font-size: 13px;
    white-space: normal;
}