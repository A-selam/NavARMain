.permission-screen {
    flex-grow: 1;
    background-color: rgb(244, 246, 252);
}

.permission-top-bar {
    height: 76px;
    flex-shrink: 0;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    padding-left: 22px;
    padding-right: 22px;
    background-color: rgb(249, 250, 253);
    border-bottom-width: 1px;
    border-bottom-color: rgb(230, 235, 244);
}

.permission-back {
    width: 36px;
    height: 36px;
    border-width: 0;
    background-color: transparent;
    color: rgb(20, 103, 223);
    font-size: 22px;
    -unity-font-style: bold;
}

.permission-brand {
    font-size: 22px;
    -unity-font-style: bold;
    color: rgb(6, 28, 67);
}

.permission-send-icon {
    width: 22px;
    height: 22px;
    border-radius: 5px;
    background-color: rgb(20, 103, 223);
}

.permission-scroll {
    flex-grow: 1;
    width: 100%;
}

.permission-container {
    flex-grow: 1;
    width: 100%;
    align-items: center;
    padding: 24px;
}

.permission-icon-circle {
    width: 168px;
    height: 168px;
    background-color: rgb(212, 224, 246);
    border-radius: 84px;
    justify-content: center;
    align-items: center;
    margin-top: 8px;
    margin-bottom: 24px;
}

.permission-icon-core {
    width: 82px;
    height: 82px;
    background-color: rgb(20, 103, 223);
    border-radius: 22px;
}

.permission-floating {
    position: absolute;
    width: 56px;
    height: 56px;
    border-radius: 14px;
    background-color: rgb(250, 251, 253);
}

.permission-floating-left {
    left: -18px;
    bottom: 22px;
}

.permission-floating-right {
    right: -18px;
    top: 18px;
}

.permission-title {
    width: 100%;
    font-size: 26px;
    -unity-font-style: bold;
    color: rgb(5, 31, 74);
    -unity-text-align: middle-center;
    margin-bottom: 12px;
}

.permission-desc {
    width: 100%;
    font-size: 14px;
    color: rgb(39, 52, 75);
    -unity-text-align: middle-center;
    white-space: normal;
    padding-left: 16px;
    padding-right: 16px;
    margin-bottom: 26px;
}

.btn-primary {
    width: 100%;
    height: 60px;
    background-color: rgb(20, 111, 226);
    color: white;
    border-radius: 30px;
    font-size: 18px;
    -unity-font-style: bold;
    border-width: 0;
    margin-bottom: 10px;
}

.btn-secondary {
    width: 100%;
    height: 48px;
    margin-bottom: 14px;
    background-color: transparent;
    color: rgb(62, 69, 84);
    font-size: 16px;
    -unity-font-style: bold;
    border-width: 0;
}

.permission-footnote {
    width: 100%;
    font-size: 12px;
    color: rgb(100, 109, 124);
    -unity-text-align: middle-center;
    white-space: normal;
    padding-left: 16px;
    padding-right: 16px;
    margin-bottom: 14px;
}

.permission-tip-card {
    width: 100%;
    min-height: 72px;
    background-color: rgb(248, 250, 253);
    border-radius: 18px;
    flex-direction: row;
    align-items: center;
    padding-left: 14px;
    padding-right: 14px;
    margin-bottom: 12px;
}

.permission-tip-icon {
    width: 40px;
    height: 40px;
    background-color: rgb(20, 111, 226);
    border-radius: 20px;
    margin-right: 12px;
}

.permission-tip-text {
    flex-grow: 1;
    color: rgb(18, 31, 54);
    font-size: 12px;
    white-space: normal;
}

.permission-feature-grid {
    width: 100%;
    flex-direction: row;
    justify-content: space-between;
    margin-bottom: 8px;
}

.permission-feature-card {
    width: 48%;
    background-color: rgb(203, 215, 239);
    border-radius: 16px;
    padding: 12px;
}

.permission-feature-icon {
    width: 36px;
    height: 36px;
    border-radius: 10px;
    background-color: rgb(237, 240, 246);
    margin-bottom: 10px;
}

.permission-feature-icon-alt {
    background-color: rgb(235, 231, 228);
}

.permission-feature-title {
    color: rgb(43, 56, 78);
    font-size: 12px;
    -unity-font-style: bold;
    margin-bottom: 6px;
}

.permission-feature-desc {
    color: rgb(8, 25, 57);
    font-size: 12px;
    -unity-font-style: bold;
}