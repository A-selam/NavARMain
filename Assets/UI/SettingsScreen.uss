.settings-screen {
    flex-grow: 1;
    background-color: rgb(244, 246, 252);
}

.settings-top-bar {
    height: 76px;
    flex-shrink: 0;
    flex-direction: row;
    align-items: center;
    padding-left: 24px;
    padding-right: 24px;
    background-color: rgb(249, 250, 253);
    border-bottom-width: 1px;
    border-bottom-color: rgb(230, 235, 244);
}

.settings-menu-icon {
    width: 18px;
    height: 14px;
    border-radius: 3px;
    background-color: rgb(20, 103, 223);
    margin-right: 14px;
}

.settings-brand {
    color: rgb(6, 28, 67);
    font-size: 22px;
    -unity-font-style: bold;
}

.settings-scroll {
    flex-grow: 1;
    width: 100%;
}

.settings-content {
    flex-grow: 1;
    width: 100%;
    padding: 24px;
}

.settings-title {
    color: rgb(6, 28, 67);
    font-size: 44px;
    -unity-font-style: bold;
    margin-bottom: 8px;
}

.settings-subtitle {
    color: rgb(39, 52, 75);
    font-size: 14px;
    white-space: normal;
    margin-bottom: 18px;
}

.settings-section-label {
    color: rgb(20, 103, 223);
    font-size: 12px;
    letter-spacing: 2px;
    -unity-font-style: bold;
    margin-bottom: 10px;
}

.settings-card {
    width: 100%;
    border-radius: 16px;
    background-color: rgb(206, 218, 240);
    padding: 12px;
    margin-bottom: 16px;
}

.settings-row {
    min-height: 76px;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    padding-left: 8px;
    padding-right: 8px;
}

.settings-row-icon {
    width: 52px;
    height: 52px;
    border-radius: 13px;
    background-color: rgb(245, 247, 251);
    margin-right: 12px;
}

.settings-row-icon-alt {
    background-color: rgb(239, 243, 248);
}

.settings-row-copy {
    flex-grow: 1;
}

.settings-row-title {
    color: rgb(8, 25, 57);
    font-size: 16px;
    -unity-font-style: bold;
    margin-bottom: 2px;
}

.settings-row-desc {
    color: rgb(39, 52, 75);
    font-size: 12px;
}

.settings-toggle {
    min-width: 72px;
    height: 38px;
    margin-left: 8px;
}

.settings-divider {
    height: 1px;
    background-color: rgb(194, 207, 233);
    margin-left: 8px;
    margin-right: 8px;
}

.settings-value {
    color: rgb(20, 103, 223);
    font-size: 30px;
    -unity-font-style: bold;
}

.settings-slider-row {
    flex-direction: row;
    align-items: center;
    padding-left: 8px;
    padding-right: 8px;
    padding-bottom: 8px;
}

.settings-slider {
    flex-grow: 1;
    margin-left: 10px;
    margin-right: 10px;
}

.settings-slider-min {
    color: rgb(104, 113, 128);
    font-size: 18px;
}

.settings-slider-max {
    color: rgb(55, 63, 80);
    font-size: 28px;
    -unity-font-style: bold;
}

.settings-help-grid {
    flex-direction: row;
    justify-content: space-between;
    margin-bottom: 16px;
}

.settings-help-card {
    width: 48%;
    height: 104px;
    border-width: 0;
    border-radius: 14px;
    background-color: rgb(206, 218, 240);
    color: rgb(7, 25, 56);
    font-size: 16px;
    -unity-font-style: bold;
}

.settings-signout {
    width: 100%;
    height: 52px;
    border-width: 0;
    border-radius: 26px;
    background-color: transparent;
    color: rgb(176, 67, 0);
    font-size: 18px;
    -unity-font-style: bold;
    margin-bottom: 12px;
}
