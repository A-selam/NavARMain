/* New destination-screen to match previous explore-screen background */
.destination-screen {
    flex-grow: 1;
    width: 100%;
    height: 100%;
    background-color: rgb(244, 246, 252);
}

.top-controls {
    width: 100%;
    padding: 18px;
    box-sizing: border-box;
    flex-direction: column;
    flex-shrink: 0;
}

.destination-list {
    width: 100%;
    flex-grow: 1;
    padding-left: 18px;
    padding-right: 18px;
    padding-bottom: 18px;
    box-sizing: border-box;
}

.explore-top-bar {
    height: 76px;
    flex-shrink: 0;
    flex-direction: row;
    align-items: center;
    padding-left: 24px;
    padding-right: 24px;
    background-color: rgb(249, 250, 253);
    border-bottom-width: 1px;
    border-bottom-color: rgb(230, 235, 244);
}

.explore-menu-icon {
    width: 18px;
    height: 14px;
    background-color: rgb(20, 103, 223);
    border-radius: 3px;
    margin-right: 14px;
}

.explore-brand-text {
    font-size: 22px;
    -unity-font-style: bold;
    color: rgb(6, 28, 67);
}

.explore-scroll {
    flex-grow: 1;
    width: 100%;
}

.destination-container {
    flex-grow: 1;
    width: 100%;
    padding: 18px;
}

.search-box {
    height: 54px;
    flex-direction: row;
    align-items: center;
    background-color: rgb(222, 230, 246);
    border-radius: 14px;
    padding-left: 16px;
    padding-right: 16px;
    margin-bottom: 14px;
}

.search-icon {
    width: 18px;
    height: 18px;
    border-radius: 9px;
    border-width: 2px;
    border-color: rgb(112, 122, 138);
    margin-right: 10px;
}

.search-input {
    flex-grow: 1;
    border-width: 0;
    background-color: transparent;
    color: rgb(106, 115, 131);
    font-size: 17px;
}

.category-scroll {
    width: 100%;
    margin-bottom: 16px;
}

.category-row {
    flex-direction: row;
    min-width: 560px;
    padding-bottom: 2px;
}

.category-pill {
    height: 46px;
    min-width: 102px;
    margin-right: 10px;
    border-radius: 23px;
    border-width: 0;
    background-color: rgb(210, 220, 238);
    color: rgb(37, 49, 70);
    font-size: 14px;
}

.category-pill-active {
    background-color: rgb(20, 111, 226);
    color: white;
}

.section-header-row {
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 10px;
}

.section-title {
    font-size: 14px;
    -unity-font-style: bold;
    color: rgb(5, 23, 52);
}

.section-spacing {
    margin-top: 16px;
    margin-bottom: 10px;
}

.section-link {
    background-color: transparent;
    border-width: 0;
    color: rgb(20, 103, 223);
    font-size: 12px;
    -unity-font-style: bold;
}

.recent-list {
    width: 100%;
    min-height: 140px;
    max-height: 200px;
    margin-bottom: 12px;
}

.destination-item {
    flex-direction: row;
    align-items: center;
    background-color: rgb(248, 249, 251);
    border-radius: 14px;
    padding: 16px;
    margin-bottom: 10px;
}

.destination-icon-box {
    width: 54px;
    height: 54px;
    background-color: rgb(214, 226, 247);
    border-radius: 10px;
    justify-content: center;
    align-items: center;
    margin-right: 14px;
}

.destination-icon-glyph {
    width: 20px;
    height: 20px;
    background-color: rgb(20, 103, 223);
    border-radius: 4px;
}

.destination-info {
    flex-grow: 1;
}

.destination-name {
    color: rgb(7, 25, 56);
    font-size: 18px;
    -unity-font-style: bold;
    margin-bottom: 2px;
}

.destination-desc {
    color: rgb(39, 52, 75);
    font-size: 12px;
}

.history-icon {
    width: 20px;
    height: 20px;
    border-width: 2px;
    border-color: rgb(110, 119, 134);
    border-radius: 10px;
}

.suggested-card {
    width: 100%;
    border-radius: 16px;
    background-color: rgb(20, 111, 226);
    padding: 18px;
    margin-bottom: 12px;
}

.suggested-ring {
    width: 54px;
    height: 54px;
    border-radius: 27px;
    border-width: 7px;
    border-color: rgba(255, 255, 255, 0.2);
    align-self: flex-end;
    margin-bottom: -38px;
}

.suggested-title {
    color: white;
    font-size: 20px;
    -unity-font-style: bold;
    margin-bottom: 4px;
}

.suggested-desc {
    color: rgb(210, 229, 255);
    font-size: 14px;
}

.quick-grid {
    flex-direction: row;
    justify-content: space-between;
    margin-bottom: 12px;
}

.quick-card {
    width: 48%;
    height: 96px;
    border-radius: 14px;
    border-width: 0;
    background-color: rgb(197, 210, 233);
    color: rgb(9, 31, 72);
    -unity-font-style: bold;
    font-size: 14px;
}

.maintenance-card {
    flex-direction: row;
    align-items: center;
    border-radius: 16px;
    background-color: rgb(246, 210, 194);
    padding: 14px;
    margin-bottom: 14px;
}

.maintenance-icon {
    width: 48px;
    height: 48px;
    border-radius: 10px;
    background-color: rgb(175, 67, 0);
    margin-right: 12px;
}

.maintenance-copy {
    flex-grow: 1;
}

.maintenance-title {
    color: rgb(46, 19, 5);
    font-size: 14px;
    -unity-font-style: bold;
    margin-bottom: 2px;
}

.maintenance-desc {
    color: rgb(97, 49, 24);
    font-size: 13px;
}

.facility-grid {
    flex-direction: row;
    justify-content: space-between;
    margin-bottom: 10px;
}

.facility-card {
    width: 48%;
    padding: 12px;
    border-radius: 14px;
    background-color: rgb(206, 218, 240);
}

.facility-image {
    width: 100%;
    height: 78px;
    border-radius: 10px;
    background-color: rgb(232, 236, 242);
    margin-bottom: 10px;
}

.facility-image-alt {
    background-color: rgb(130, 139, 155);
}

.facility-name {
    color: rgb(9, 27, 58);
    font-size: 14px;
    -unity-font-style: bold;
}